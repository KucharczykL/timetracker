{
	auto_https off
}

:8000 {
	handle_path /static/* {
		root * /home/timetracker/app/static
		@hashed path_regexp hashed \.[0-9a-f]{12}\.
		header @hashed Cache-Control "public, max-age=31536000, immutable"
		file_server
	}
	handle /robots.txt {
		root * /home/timetracker/app/games/static
		file_server
	}
	reverse_proxy localhost:8001
}
